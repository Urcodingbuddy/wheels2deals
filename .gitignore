# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# video files (large binaries — hosted on Supabase Storage)
*.mp4
*.webm
*.mov
*.avi
*.mkv

# local design reference folders
bmw/
ferrari/
lamborghini/
porsche/
renault/
tesla/

# Claude Code local settings
.claude/

# MCP config (project-local)
.mcp.json
